SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase service role (仅服务器环境使用)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI (本地操作使用)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
VERCEL_TOKEN=

# App Configuration
APP_NAME=
APP_VERSION=

# Google Play Server API
GOOGLE_PLAY_SERVICE_ACCOUNT=
GOOGLE_PLAY_PACKAGE_NAME=

# BytePlus Seedream（Supabase Edge Function 使用）
SEEDREAM_API_KEY=
SEEDREAM_PROMPT=
# 当前默认模型（ByteDance-Seedream-5.0-lite / 260128）
SEEDREAM_MODEL=seedream-5-0-260128

# OpenAI（美国地区 Web 图像编辑使用）
OPENAI_API_KEY=
# 可选：默认使用 gpt-image-1.5，也可改为其他可用别名
OPENAI_IMAGE_MODEL=gpt-image-1.5
# 可选：未设置时回退到 SEEDREAM_PROMPT
OPENAI_IMAGE_PROMPT=

# PayPal Live（Web + Supabase Edge Functions）
PAYPAL_ENV=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
